<%- include('partials/header', { title: 'Hem' }) %>

<section class="hero">
  <h1>Gratis pantburkar nära dig</h1>
  <p>Någon ställer ut sina burkar. Du hämtar dem och behåller panten.</p>
  <div class="hero-actions">
    <a href="/annonser" class="btn-primary">Hitta burkar</a>
    <a href="/lämna" class="btn-secondary">Lämna dina burkar</a>
  </div>
</section>

<% if (listings.length > 0) { %>
<section class="section">
  <h2>Senast utlagda</h2>
  <div class="insta-grid">
    <% listings.forEach(listing => { %>
    <a href="/annons/<%= listing.id %>" class="insta-card">
      <div class="insta-img">
        <% if (listing.image) { %>
          <img src="<%= listing.image %>" alt="Pantburkar i <%= listing.location %>">
        <% } else { %>
          <%- include('partials/can-placeholder') %>
        <% } %>
        <span class="badge badge-pant">~<%= listing.pantVarde %> kr · <%= listing.antal %> st</span>
      </div>
      <div class="insta-hover">
        <p class="insta-title"><%= listing.antal %> burkar</p>
        <p class="insta-meta"><%= listing.location %></p>
      </div>
    </a>
    <% }) %>
  </div>
  <div class="center" style="margin-top:2rem"><a href="/annonser" class="btn-outline">Visa alla annonser</a></div>
</section>
<% } else { %>
<section class="section">
  <div class="empty-state">
    <p>Inga burkar utlagda ännu.</p>
    <a href="/lämna" class="btn-primary">Bli den första</a>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>
