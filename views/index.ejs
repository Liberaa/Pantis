<%- include('partials/header', { title: 'Hem' }) %>

<section class="hero">
  <h1>Köp & sälj byxor i Sverige</h1>
  <p>Hitta ett fynd eller ge dina byxor nytt liv.</p>
  <div class="hero-actions">
    <a href="/annonser" class="btn-primary">Se alla annonser</a>
    <a href="/sälj" class="btn-secondary">Lägg upp annons</a>
  </div>
</section>

<% if (listings.length > 0) { %>
<section class="section">
  <h2>Senaste annonserna</h2>
  <div class="grid">
    <% listings.forEach(listing => { %>
    <a href="/annons/<%= listing.id %>" class="card">
      <div class="card-img">
        <% if (listing.image) { %>
          <img src="<%= listing.image %>" alt="<%= listing.title %>">
        <% } else { %>
          <div class="card-img-placeholder">👖</div>
        <% } %>
      </div>
      <div class="card-body">
        <h3><%= listing.title %></h3>
        <p class="price"><%= listing.price %> kr</p>
        <p class="meta"><%= listing.size %> · <%= listing.location %></p>
      </div>
    </a>
    <% }) %>
  </div>
  <div class="center"><a href="/annonser" class="btn-outline">Visa alla</a></div>
</section>
<% } %>

<%- include('partials/footer') %>
