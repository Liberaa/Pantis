<%- include('partials/header', { title: 'Hem' }) %>

<section class="hero">
  <h1>Köp & sälj byxor i Sverige</h1>
  <p>Hitta ett fynd eller ge dina byxor nytt liv.</p>
  <div class="hero-actions">
    <a href="/annonser" class="btn-primary">Se flödet</a>
    <a href="/sälj" class="btn-secondary">Lägg upp annons</a>
  </div>
</section>

<% if (listings.length > 0) { %>
<section class="section">
  <h2>Senaste byxorna</h2>
  <div class="insta-grid">
    <% listings.forEach(listing => { %>
    <a href="/annons/<%= listing.id %>" class="insta-card">
      <div class="insta-img">
        <% if (listing.image) { %>
          <img src="<%= listing.image %>" alt="<%= listing.title %>">
        <% } else { %>
          <div class="insta-placeholder">👖</div>
        <% } %>
        <% if (listing.free) { %>
          <span class="badge badge-free">GRATIS</span>
        <% } else { %>
          <span class="badge badge-price"><%= listing.price %> kr</span>
        <% } %>
      </div>
      <div class="insta-hover">
        <p class="insta-title"><%= listing.title %></p>
        <p class="insta-meta"><%= listing.size %> · <%= listing.location %></p>
      </div>
    </a>
    <% }) %>
  </div>
  <div class="center"><a href="/annonser" class="btn-outline">Visa alla annonser</a></div>
</section>
<% } else { %>
<section class="section empty-state">
  <p>Inga annonser ännu — bli den första!</p>
  <a href="/sälj" class="btn-primary">Lägg upp byxor</a>
</section>
<% } %>

<%- include('partials/footer') %>
