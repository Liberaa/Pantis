<%- include('partials/header', { title: 'Flöde' }) %>

<div class="feed-header">
  <form class="filter-form" method="GET" action="/">
    <input type="text" name="search" placeholder="Sök ort..." value="<%= search %>">
    <select name="typ">
      <option value="">Alla typer</option>
      <option value="1kr" <%= typ === '1kr' ? 'selected' : '' %>>1 kr</option>
      <option value="2kr" <%= typ === '2kr' ? 'selected' : '' %>>2 kr</option>
      <option value="3kr" <%= typ === '3kr' ? 'selected' : '' %>>3 kr</option>
      <option value="blandat" <%= typ === 'blandat' ? 'selected' : '' %>>Blandat</option>
    </select>
    <button type="submit" class="btn-filter">Filtrera</button>
    <% if (search || typ) { %>
      <a href="/" class="btn-clear">Rensa</a>
    <% } %>
  </form>
</div>

<% if (listings.length === 0) { %>
  <div class="section">
    <div class="empty-state">
      <p>Inga burkar tillgängliga just nu.</p>
      <% if (currentUser) { %>
        <a href="/lämna" class="btn-primary">Lämna dina burkar</a>
      <% } else { %>
        <a href="/registrera" class="btn-primary">Kom igång</a>
      <% } %>
    </div>
  </div>
<% } else { %>
  <% if (search || typ) { %>
    <p class="feed-count"><%= listings.length %> annons<%= listings.length !== 1 ? 'er' : '' %></p>
  <% } %>
  <div class="insta-grid">
    <% listings.forEach(listing => { %>
    <a href="/annons/<%= listing.id %>" class="insta-card">
      <div class="insta-img">
        <% if (listing.image) { %>
          <img src="<%= listing.image %>" alt="Pantburkar i <%= listing.location %>">
        <% } else { %>
          <%- include('partials/can-placeholder') %>
        <% } %>
        <span class="badge badge-pant">~<%= listing.pantVarde %> kr · <%= listing.antal %> st</span>
      </div>
      <div class="insta-hover">
        <p class="insta-title"><%= listing.antal %> burkar</p>
        <p class="insta-meta"><%= listing.location %></p>
      </div>
    </a>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
