<%- include('partials/header', { title: listing.antal + ' burkar i ' + listing.location }) %>

<section class="section listing-detail">
  <a href="/annonser" class="back-link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
    Tillbaka
  </a>

  <div class="listing-layout">
    <div class="listing-image">
      <% if (listing.image) { %>
        <img src="<%= listing.image %>" alt="Pantburkar i <%= listing.location %>">
      <% } else { %>
        <div class="img-placeholder-large">
          <%- include('partials/can-placeholder') %>
        </div>
      <% } %>
    </div>

    <div class="listing-info">
      <% if (listing.reserved) { %>
        <div class="reserved-banner">Dessa burkar är redan reserverade</div>
      <% } else { %>
        <div class="free-banner">Gratis att hämta — du behåller panten</div>
      <% } %>

      <h1>~<%= listing.antal %> burkar i <%= listing.location %></h1>

      <div class="pant-value-box">
        <span class="pant-label">Uppskattad pantvärd</span>
        <span class="pant-amount">~<%= listing.pantVarde %> kr</span>
      </div>

      <div class="tags">
        <span class="tag"><%= listing.typ %></span>
        <span class="tag"><%= listing.antal %> st</span>
        <span class="tag"><%= listing.location %></span>
      </div>

      <% if (listing.description) { %>
        <p class="description"><%= listing.description %></p>
      <% } %>

      <% if (!listing.reserved) { %>
        <div class="cart-actions">
          <button
            class="btn-primary btn-large btn-add-cart"
            id="cart-btn"
            onclick="toggleCart('<%= listing.id %>', this)"
          >
            Lägg i hämtlista
          </button>
          <a href="/varukorg" class="btn-outline btn-large">
            Se hämtlista
          </a>
        </div>
      <% } %>

      <div class="contact-box">
        <h3>Kontakta för upphämtning</h3>
        <p><%= listing.contact %></p>
      </div>

      <p class="date">Publicerad: <%= listing.createdAt.toLocaleDateString('sv-SE') %></p>
    </div>
  </div>
</section>

<script>
  updateCartBtn('<%= listing.id %>', document.getElementById('cart-btn'))
</script>

<%- include('partials/footer') %>
