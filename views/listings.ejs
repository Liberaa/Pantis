<%- include('partials/header', { title: 'Flöde' }) %>

<section class="section">
  <h1>Tillgängliga burkar</h1>

  <form class="filter-form" method="GET" action="/annonser">
    <input type="text" name="search" placeholder="Sök ort..." value="<%= search || '' %>">
    <select name="typ">
      <option value="">Alla typer</option>
      <option value="1kr" <%= typ === '1kr' ? 'selected' : '' %>>1 kr – Liten burk / flaska</option>
      <option value="2kr" <%= typ === '2kr' ? 'selected' : '' %>>2 kr – Stor plastflaska</option>
      <option value="3kr" <%= typ === '3kr' ? 'selected' : '' %>>3 kr – Glasflaska</option>
      <option value="blandat" <%= typ === 'blandat' ? 'selected' : '' %>>Blandat</option>
    </select>
    <button type="submit" class="btn-primary">Filtrera</button>
    <% if (search || typ) { %>
      <a href="/annonser" class="btn-outline">Rensa</a>
    <% } %>
  </form>

  <% if (listings.length === 0) { %>
    <div class="empty-state">
      <p>Inga burkar hittades.</p>
      <a href="/lämna" class="btn-primary">Lämna dina burkar</a>
    </div>
  <% } else { %>
    <p class="result-count"><%= listings.length %> annons<%= listings.length !== 1 ? 'er' : '' %></p>
    <div class="insta-grid">
      <% listings.forEach(listing => { %>
      <a href="/annons/<%= listing.id %>" class="insta-card">
        <div class="insta-img">
          <% if (listing.image) { %>
            <img src="<%= listing.image %>" alt="Pantburkar i <%= listing.location %>">
          <% } else { %>
            <%- include('partials/can-placeholder') %>
          <% } %>
          <span class="badge badge-pant">~<%= listing.pantVarde %> kr</span>
        </div>
        <div class="insta-hover">
          <p class="insta-title"><%= listing.antal %> st – <%= listing.typ %></p>
          <p class="insta-meta"><%= listing.location %></p>
        </div>
      </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
