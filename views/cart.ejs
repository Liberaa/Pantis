<%- include('partials/header', { title: 'Hämtlista' }) %>

<section class="section">
  <h1>Din hämtlista</h1>

  <div id="cart-empty" style="display:none">
    <div class="empty-state">
      <p>Din hämtlista är tom.</p>
      <a href="/" class="btn-primary">Hitta burkar</a>
    </div>
  </div>

  <div id="cart-loading">
    <p style="color:var(--muted)">Laddar...</p>
  </div>

  <div id="cart-content" style="display:none">
    <div id="cart-items" class="cart-list"></div>
    <div class="cart-summary" id="cart-summary">
      <div class="summary-row">
        <span>Antal annonser</span>
        <span id="summary-count">0</span>
      </div>
      <div class="summary-row summary-total">
        <span>Uppskattad pantvärd</span>
        <span id="summary-value">0 kr</span>
      </div>
      <a href="/kassa" class="btn-primary btn-large" style="display:block;text-align:center;margin-top:1.25rem">
        Gå till kassan
      </a>
    </div>
  </div>
</section>

<script>
async function loadCart() {
  const ids = getCart()
  const loading = document.getElementById('cart-loading')
  const empty = document.getElementById('cart-empty')
  const content = document.getElementById('cart-content')

  if (ids.length === 0) {
    loading.style.display = 'none'
    empty.style.display = 'block'
    return
  }

  const res = await fetch('/api/listings?ids=' + ids.join(','))
  const listings = await res.json()
  loading.style.display = 'none'

  if (listings.length === 0) {
    empty.style.display = 'block'
    return
  }

  content.style.display = 'block'
  const container = document.getElementById('cart-items')
  let totalVarde = 0

  listings.forEach(l => {
    totalVarde += l.pantVarde
    const item = document.createElement('div')
    item.className = 'cart-item'
    item.id = 'item-' + l.id
    item.innerHTML = `
      <div class="cart-item-img">
        ${l.image ? `<img src="${l.image}" alt="">` : '<div class="cart-img-placeholder"><svg viewBox="0 0 48 72" fill="none"><rect x="15" y="2" width="18" height="9" rx="3" fill="#2e2e2e"/><ellipse cx="24" cy="11" rx="16" ry="5" fill="#252525" stroke="#333" stroke-width="1.5"/><rect x="8" y="11" width="32" height="50" fill="#1e1e1e" stroke="#333" stroke-width="1.5"/><ellipse cx="24" cy="61" rx="16" ry="5" fill="#252525" stroke="#333" stroke-width="1.5"/></svg></div>'}
      </div>
      <div class="cart-item-info">
        <h3>~${l.antal} burkar i ${l.location}</h3>
        <p class="meta">${l.typ} &middot; ~${l.pantVarde} kr pantvärd</p>
        ${l.reserved ? '<span class="reserved-tag">Redan reserverad</span>' : ''}
      </div>
      <button class="cart-remove" aria-label="Ta bort" onclick="removeItem('${l.id}')">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    `
    container.appendChild(item)
  })

  document.getElementById('summary-count').textContent = listings.length
  document.getElementById('summary-value').textContent = '~' + totalVarde + ' kr'
}

function removeItem(id) {
  removeFromCart(id)
  const el = document.getElementById('item-' + id)
  if (el) el.remove()
  updateCartCount()
  if (getCart().length === 0) location.reload()
}

loadCart()
</script>

<%- include('partials/footer') %>
