<%- include('partials/header', { title: 'Sälj byxor' }) %>

<section class="section">
  <h1>Lägg upp annons</h1>

  <form class="listing-form" action="/sälj" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="title">Titel *</label>
      <input type="text" id="title" name="title" placeholder="T.ex. Levis 501 mörkblå" required>
    </div>

    <div class="form-group">
      <label for="description">Beskrivning *</label>
      <textarea id="description" name="description" rows="4" placeholder="Beskriv byxorna, material, detaljer..." required></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="price">Pris (kr) *</label>
        <input type="number" id="price" name="price" min="0" placeholder="250" required>
      </div>

      <div class="form-group">
        <label for="size">Storlek *</label>
        <select id="size" name="size" required>
          <option value="">Välj storlek</option>
          <% ['XS','S','M','L','XL','XXL','28','29','30','31','32','33','34','36','38','40'].forEach(s => { %>
            <option value="<%= s %>"><%= s %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="condition">Skick *</label>
        <select id="condition" name="condition" required>
          <option value="">Välj skick</option>
          <% ['Nytt', 'Mycket bra', 'Bra', 'Acceptabelt'].forEach(c => { %>
            <option value="<%= c %>"><%= c %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="location">Ort *</label>
        <input type="text" id="location" name="location" placeholder="T.ex. Stockholm" required>
      </div>

      <div class="form-group">
        <label for="contact">Kontakt (e-post eller telefon) *</label>
        <input type="text" id="contact" name="contact" placeholder="din@email.se" required>
      </div>
    </div>

    <div class="form-group">
      <label for="image">Bild</label>
      <input type="file" id="image" name="image" accept="image/*">
    </div>

    <button type="submit" class="btn-primary btn-large">Publicera annons</button>
  </form>
</section>

<%- include('partials/footer') %>
