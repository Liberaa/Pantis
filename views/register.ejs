<%- include('partials/header', { title: 'Registrera' }) %>

<div class="auth-page">
  <div class="auth-box">
    <a href="/" class="logo auth-logo">Pantis</a>
    <h1>Skapa konto</h1>

    <% if (error) { %>
      <div class="auth-error"><%= error %></div>
    <% } %>

    <form action="/registrera" method="POST">
      <div class="form-group">
        <label for="name">Namn</label>
        <input type="text" id="name" name="name" placeholder="Anna Svensson" required autofocus>
      </div>
      <div class="form-group">
        <label for="email">E-post</label>
        <input type="email" id="email" name="email" placeholder="din@email.se" required>
      </div>
      <div class="form-group">
        <label for="password">Lösenord</label>
        <input type="password" id="password" name="password" placeholder="Minst 6 tecken" minlength="6" required>
      </div>

      <button type="submit" class="btn-primary btn-large">Skapa konto</button>
    </form>

    <p class="auth-switch">Har du redan konto? <a href="/loggain">Logga in</a></p>
  </div>
</div>

<%- include('partials/footer') %>
